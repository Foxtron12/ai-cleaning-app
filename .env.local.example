# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App URL (used for auth redirects and magic links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Smoobu API (fallback – per-user key stored in settings table takes priority)
SMOOBU_API_KEY=your_smoobu_api_key_here

# Webhook Security (choose any random string)
SMOOBU_WEBHOOK_SECRET=your_webhook_secret_here

# Admin impersonation (min. 32 chars, random – keep secret)
ADMIN_SECRET=your_very_long_random_admin_secret_here
