# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App URL (used for auth redirects and magic links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Encryption (PROJ-11: per-user API key encryption)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
# Optional: previous key for rotation (set when rotating ENCRYPTION_KEY)
# ENCRYPTION_KEY_PREVIOUS=old_64_char_hex_encryption_key_here

# Admin impersonation (min. 32 chars, random – keep secret)
ADMIN_SECRET=your_very_long_random_admin_secret_here

# Stripe (Payment Gate – PROJ-12)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_stripe_price_id_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
NEXT_PUBLIC_STRIPE_ENABLED=false

# Cron Job Secret (Auto-Nachrichten, min. 32 chars)
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
